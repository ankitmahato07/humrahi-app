# ============================================================
# Humrahi App — Environment Variables
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local or any file with real secrets.
# ============================================================

# ── Supabase (required) ──────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API

# Public — safe to expose in browser bundles
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...YOUR_ANON_KEY

# Server-only — NEVER expose to browser; used only in Server Actions / Route Handlers
SUPABASE_SERVICE_ROLE_KEY=eyJ...YOUR_SERVICE_ROLE_KEY

# ── App URLs (required) ──────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.myhumrahi.org
NEXT_PUBLIC_STATIC_SITE_URL=https://www.myhumrahi.org

# ── Sevastack donate link (required) ────────────────────────
# The URL donors are sent to when clicking "Give again" or donate CTAs
NEXT_PUBLIC_SEVASTACK_DONATE_URL=https://donate.sevastack.in/humrahi-foundation

# ── WhatsApp community (required) ───────────────────────────
NEXT_PUBLIC_WHATSAPP_COMMUNITY_URL=https://chat.whatsapp.com/YOUR_INVITE_CODE

# ── SMS / OTP provider (required for phone auth) ─────────────
# Configured in Supabase Dashboard → Authentication → SMS Provider
# Choose Twilio, MessageBird, or Vonage.
# DLT registration (India TRAI) required before production use.
# See docs/sms-dlt-setup.md for the India DLT registration guide.
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...     # or your DLT-registered sender ID
# TWILIO_VERIFY_SERVICE_SID=VA... # if using Twilio Verify instead of raw OTP

# ── Sevastack sync (fill after probe — see docs/sevastack-integration.md) ──
# Path A: webhook
SEVASTACK_WEBHOOK_SECRET=       # shared secret Sevastack sends with each webhook

# Path B: Google Sheets sync
SEVASTACK_SHEET_ID=             # Google Sheet ID from the URL
GOOGLE_SERVICE_ACCOUNT_JSON=    # full JSON blob of the service-account key

# ── Razorpay (online donations at /donate) ──────────────────
# Dashboard → Settings → API Keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_...   # public, shipped to the browser
RAZORPAY_KEY_SECRET=...                    # server-only, NEVER expose
# Dashboard → Settings → Webhooks → create webhook for payment.captured
# pointing at https://app.myhumrahi.org/api/razorpay/webhook
RAZORPAY_WEBHOOK_SECRET=...

# ── Email (optional — for data-request notifications) ───────
RESEND_API_KEY=re_...           # or use Netlify form notifications for wecare@
